{
  "name": "integrated-browser-on-activity-bar",
  "displayName": "Integrated Browser Button",
  "description": "Adds an Activity Bar shortcut to VS Code's Integrated Browser (introduced in v1.109) with support for Favorite Tabs.",
  "version": "0.0.10",
  "publisher": "oleksiiko",
  "repository": {
    "type": "git",
    "url": "https://github.com/konashevich/integrated-browser-bookmarks-to-activity-bar.git"
  },
  "icon": "media/icon.png",
  "engines": { "vscode": "^1.70.0" },
  "activationEvents": [
    "onView:integratedBrowser.view",
    "onCommand:integratedBrowser.open",
    "onCommand:integratedBrowser.openHtmlFile",
    "onCommand:integratedBrowser.openClipboardLocalFile"
  ],
  "main": "./extension.js",
  "scripts": {
    "publish": "vsce publish"
  },
  "files": [
    "extension.js",
    "README.md",
    "LICENSE",
    "media/browser.svg",
    "media/icon.png",
    "media/demo.gif"
  ],
  "categories": ["Other"],
  "contributes": {
    "commands": [
      {
        "command": "integratedBrowser.open",
        "title": "Browser: Open Integrated Browser"
      },
      {
        "command": "integratedBrowser.openHtmlFile",
        "title": "Browser: Open HTML File in Integrated Browser",
        "icon": "$(globe)"
      },
      {
        "command": "integratedBrowser.openClipboardLocalFile",
        "title": "Browser: Open Local File from Clipboard",
        "icon": "$(clippy)"
      },
      {
        "command": "integratedBrowser.addFavorite",
        "title": "Browser: Add Favorite",
        "icon": "$(add)"
      },
      {
        "command": "integratedBrowser.deleteFavorite",
        "title": "Browser: Delete Favorite",
        "icon": "$(trash)"
      },
      {
        "command": "integratedBrowser.openFavorite",
        "title": "Browser: Open Favorite",
        "icon": "$(link-external)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "integratedBrowser.openHtmlFile",
          "when": "resourceScheme == file && (resourceExtname == '.html' || resourceExtname == '.htm' || resourceExtname == '.xhtml' || resourceExtname == '.HTML' || resourceExtname == '.HTM' || resourceExtname == '.XHTML')",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "integratedBrowser.openHtmlFile",
          "when": "resourceScheme == file && (resourceExtname == '.html' || resourceExtname == '.htm' || resourceExtname == '.xhtml' || resourceExtname == '.HTML' || resourceExtname == '.HTM' || resourceExtname == '.XHTML')",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "integratedBrowser.openClipboardLocalFile",
          "when": "view == integratedBrowser.view",
          "group": "navigation@1"
        },
        {
          "command": "integratedBrowser.addFavorite",
          "when": "view == integratedBrowser.view",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "integratedBrowser.openFavorite",
          "when": "view == integratedBrowser.view && viewItem == favorite",
          "group": "inline"
        },
        {
          "command": "integratedBrowser.deleteFavorite",
          "when": "view == integratedBrowser.view && viewItem == favorite",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        { "id": "integratedBrowser", "title": "Browser", "icon": "media/browser.svg" }
      ]
    },
    "views": {
      "integratedBrowser": [
        {
          "id": "integratedBrowser.view",
          "name": "Integrated Browser",
          "contextualTitle": "Browser"
        }
      ]
    }
  }
}
